rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // User profile pictures — only the owner can write to their own folder
    match /users/{userId}/{allPaths=**} {
      allow read:  if request.auth != null;
      allow write: if request.auth != null
                   && request.auth.uid == userId
                   && request.resource.size < 15 * 1024 * 1024;
    }

    // All other uploads (post images, comment media, conversation files)
    match /{allPaths=**} {
      allow read:  if request.auth != null;
      allow write: if request.auth != null
                   && request.resource.size < 15 * 1024 * 1024;
    }
  }
}
